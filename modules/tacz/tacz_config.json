{
  "module": "tacz",
  "description": "Timeless and Classics Zero (TACZ) — Brain mapping, role definitions, and default loadouts. Roles are managed here; NPC assignment is done by attaching the matching role script (modules/tacz/roles/<roleId>.js) directly to the NPC in CNPC.",

  "default_brain_provider": "gemini",

  "roles": {
    "squad_leader": {
      "description": "Commanding officer. Coordinates the squad, issues formation orders, and maintains tactical awareness.",
      "brain_provider": "gemini",
      "goals": ["patrol", "engage_hostiles", "report_contacts", "follow_player_on_order", "coordinate_squad", "maintain_formation"]
    },
    "soldier": {
      "description": "Standard infantry. Executes orders from the squad leader or player. Engages threats on sight.",
      "brain_provider": "gemini",
      "goals": ["patrol", "engage_hostiles", "follow_player_on_order", "suppress_hostiles", "follow_leader_formation"]
    },
    "sniper": {
      "description": "Long-range specialist. Holds overwatch position and eliminates priority targets with precision.",
      "brain_provider": "gemini",
      "goals": ["hold_position", "engage_priority_targets", "report_contacts", "follow_leader_formation"]
    },
    "medic": {
      "description": "Field medic. Treats wounded allies and keeps the squad operational under fire.",
      "brain_provider": "gemini",
      "goals": ["treat_wounded", "follow_leader_formation", "follow_player_on_order", "engage_hostiles"]
    },
    "launcher": {
      "description": "Heavy weapons specialist. Provides rocket and explosive fire support against hardened targets.",
      "brain_provider": "gemini",
      "goals": ["fire_support", "engage_priority_targets", "hold_position", "follow_leader_formation"]
    },
    "scout": {
      "description": "Forward scout. Moves ahead of the squad to gather intel and mark enemy positions.",
      "brain_provider": "gemini",
      "goals": ["scout_area", "report_contacts", "follow_leader_formation", "engage_hostiles"]
    },
    "rifleman": {
      "description": "Standard infantry soldier. Engages targets at medium range.",
      "brain_provider": "gemini",
      "goals": ["patrol", "engage_hostiles", "follow_player_on_order", "follow_leader_formation"]
    },
    "support": {
      "description": "Heavy weapons or logistics. Suppresses enemies and resupplies allies.",
      "brain_provider": "gemini",
      "goals": ["suppress_hostiles", "resupply_allies", "secure_area", "follow_leader_formation"]
    }
  },

